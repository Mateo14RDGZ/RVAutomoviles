# Copiá este archivo a `.env.local` y completá los valores.

# Contraseña del panel /admin (una sola cuenta por ahora)
ADMIN_PASSWORD=cambiar-esto

# Secreto para firmar la cookie de sesión (string largo aleatorio)
SESSION_SECRET=cambiar-por-un-secreto-largo-aleatorio

# URL pública del sitio (opcional, mejora metadatos y enlaces absolutos)
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
