# === Copiá a `.env.local` o pegá en Vercel → Environment Variables ===
#
# Valores de EJEMPLO (cambiá contraseña y secreto en producción real):
ADMIN_PASSWORD=RvAutos2026_Demo_Clave
SESSION_SECRET=9c8b7a6f5e4d3c2b1a0f9e8d7c6b5a4f3e2d1c0b9a8f7e6d5c4b3a2f1e0d9c8b7a6f5e4d3c2b1a0f9e8d7c6b5a4f3e2d1c0b9a8f7e6d5c4b3a2f1e0d9c8
#
# Neon / Postgres (en Vercel: Storage → Postgres → conectar; NO inventar la URL):
# Usá la cadena con pooling para serverless si Neon la ofrece (host con -pooler).
# DATABASE_URL=postgresql://usuario:clave@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# Si Vercel solo te da POSTGRES_URL o POSTGRES_PRISMA_URL, la app también las lee.
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
#
# Vercel Blob (Storage → Blob → conectar; token real, no inventar):
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
# Opcional: URL canónica (si no, en Vercel se usa https:// + VERCEL_URL)
# NEXT_PUBLIC_APP_URL=https://tu-proyecto.vercel.app
